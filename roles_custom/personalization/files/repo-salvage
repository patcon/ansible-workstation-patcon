#!/usr/bin/env bash
# Scans ~/repos for anything that could be lost: uncommitted changes, stashes,
# and local branches with unpushed commits or no remote at all.
# Usage: repo-salvage [scan|push] [repos-dir]
set -uo pipefail

CMD="${1:-scan}"
REPOS_DIR="${2:-$HOME/repos}"

if [[ ! -d "$REPOS_DIR" ]]; then
  echo "Directory not found: $REPOS_DIR" >&2
  exit 1
fi

if [[ -t 1 ]]; then
  RED='\033[0;31m'
  YELLOW='\033[1;33m'
  GREEN='\033[0;32m'
  BOLD='\033[1m'
  DIM='\033[2m'
  RESET='\033[0m'
else
  RED=''; YELLOW=''; GREEN=''; BOLD=''; DIM=''; RESET=''
fi

cmd_scan() {
  local clean_repos=()
  local dirty_repos=()

  for dir in "$REPOS_DIR"/*/; do
    [[ -d "$dir/.git" ]] || continue
    local repo issues
    repo=$(basename "$dir")
    issues=()

    pushd "$dir" > /dev/null

    local status_out
    status_out=$(git status --porcelain 2>/dev/null)
    if [[ -n "$status_out" ]]; then
      local count
      count=$(printf '%s\n' "$status_out" | wc -l | tr -d ' ')
      issues+=("${YELLOW}DIRTY${RESET}     $count file(s) with uncommitted changes")
    fi

    local stash_out
    stash_out=$(git stash list 2>/dev/null)
    if [[ -n "$stash_out" ]]; then
      local count
      count=$(printf '%s\n' "$stash_out" | wc -l | tr -d ' ')
      issues+=("${RED}STASH${RESET}     $count stash(es)")
    fi

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue
      local upstream
      upstream=$(git rev-parse --abbrev-ref "${branch}@{u}" 2>/dev/null || true)
      if [[ -z "$upstream" ]]; then
        local commit_count
        commit_count=$(git rev-list --count HEAD 2>/dev/null || echo "?")
        issues+=("${RED}NO REMOTE${RESET} branch '${branch}' has no upstream (${commit_count} commit(s))")
      else
        local ahead
        ahead=$(git rev-list --count "${upstream}..${branch}" 2>/dev/null || echo 0)
        if [[ "$ahead" -gt 0 ]]; then
          issues+=("${YELLOW}UNPUSHED${RESET}  branch '${branch}': ${ahead} commit(s) ahead of ${upstream}")
        fi
      fi
    done < <(git branch --format='%(refname:short)' 2>/dev/null)

    popd > /dev/null

    if [[ ${#issues[@]} -gt 0 ]]; then
      printf "${BOLD}%s/${RESET}\n" "$repo"
      for issue in "${issues[@]}"; do
        printf "  ${issue}\n"
      done
      dirty_repos+=("$repo")
    else
      clean_repos+=("$repo")
    fi
  done

  echo ""
  printf "${BOLD}Summary${RESET}\n"
  printf "  ${GREEN}Clean${RESET}            %d repo(s)\n" "${#clean_repos[@]}"
  printf "  ${RED}Need attention${RESET}   %d repo(s)\n" "${#dirty_repos[@]}"
  if [[ ${#dirty_repos[@]} -gt 0 ]]; then
    for r in "${dirty_repos[@]}"; do
      printf "    ${DIM}- %s${RESET}\n" "$r"
    done
  fi
}

cmd_push() {
  local pushed=0
  local failed=0
  local skipped=0

  for dir in "$REPOS_DIR"/*/; do
    [[ -d "$dir/.git" ]] || continue
    local repo
    repo=$(basename "$dir")

    pushd "$dir" > /dev/null

    while IFS= read -r branch; do
      [[ -z "$branch" ]] && continue

      local upstream
      upstream=$(git rev-parse --abbrev-ref "${branch}@{u}" 2>/dev/null || true)

      if [[ -z "$upstream" ]]; then
        if git remote get-url origin &>/dev/null; then
          printf "${BOLD}%s${RESET} branch '${branch}': pushing to origin (no upstream set)...\n" "$repo"
          if git push --set-upstream origin "$branch" 2>&1 | sed 's/^/  /'; then
            (( pushed++ )) || true
          else
            printf "  ${RED}failed${RESET}\n"
            (( failed++ )) || true
          fi
        else
          printf "${BOLD}%s${RESET} branch '${branch}': ${DIM}skipped (no origin remote)${RESET}\n" "$repo"
          (( skipped++ )) || true
        fi
      else
        local ahead
        ahead=$(git rev-list --count "${upstream}..${branch}" 2>/dev/null || echo 0)
        if [[ "$ahead" -gt 0 ]]; then
          printf "${BOLD}%s${RESET} branch '${branch}': pushing ${ahead} commit(s) to ${upstream}...\n" "$repo"
          if git push 2>&1 | sed 's/^/  /'; then
            (( pushed++ )) || true
          else
            printf "  ${RED}failed${RESET}\n"
            (( failed++ )) || true
          fi
        fi
      fi
    done < <(git branch --format='%(refname:short)' 2>/dev/null)

    popd > /dev/null
  done

  echo ""
  printf "${BOLD}Summary${RESET}\n"
  printf "  ${GREEN}Pushed${RESET}   %d branch(es)\n" "$pushed"
  printf "  ${RED}Failed${RESET}   %d branch(es)\n" "$failed"
  printf "  ${DIM}Skipped  %d branch(es)${RESET}\n" "$skipped"
}

case "$CMD" in
  scan) cmd_scan ;;
  push) cmd_push ;;
  *)
    printf "Usage: repo-salvage [scan|push] [repos-dir]\n" >&2
    exit 1
    ;;
esac
