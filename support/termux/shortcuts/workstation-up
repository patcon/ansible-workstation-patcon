#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

# Termux Widget runs in a real terminal; bail early in non-interactive contexts
if ! test -w /dev/tty; then
  echo "Error: /dev/tty not available — run this in a real terminal" >&2
  exit 1
fi

REPO=~/repos/ansible-workstation-patcon

# Create server; show output but capture final line (server name)
name=$(cd "$REPO" && scripts/hcloud-workstation up | tee /dev/tty | tail -1)

# Get IP via python3 (available on Termux without extra deps)
ip=$(hcloud server describe "$name" -o json \
  | python3 -c "import sys,json; print(json.load(sys.stdin)['public_net']['ipv4']['ip'])")

# Phase 1: root SSH — install Ansible, run bootstrap (creates patcon user, hardens SSH)
echo "Waiting for SSH on $ip..."
until ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no root@"$ip" true 2>/dev/null; do
  sleep 5
done
make -C "$REPO" remote_init REMOTE_HOST="$ip"

# Phase 2: patcon SSH — full converge (root SSH now disabled after hardening)
echo "Waiting for SSH as patcon on $ip..."
until ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no patcon@"$ip" true 2>/dev/null; do
  sleep 5
done
ssh -A -o StrictHostKeyChecking=no patcon@"$ip" \
  'cd /tmp/ansible-workstation-patcon && sudo --preserve-env=SSH_AUTH_SOCK make local_converge'
