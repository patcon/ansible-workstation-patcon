#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [options]

Commands:
  up [name]          Create a new server (auto-names: workstation-main, then workstation-test1, test2, ...)
  down <name> [-y|--yes]   Delete a server by name
  list               List all servers
  ssh-config         Sync ~/.ssh/config.d/hcloud-* with current server IPs

Options:
  -h, --help    Show this help
EOF
}

die() { echo "Error: $*" >&2; exit 1; }

require_hcloud() {
  if ! command -v hcloud &>/dev/null; then
    if [[ "$PREFIX" == *com.termux* ]]; then
      die "hcloud not found — install it with: pkg install hcloud"
    else
      die "hcloud CLI not found in PATH"
    fi
  fi
}

cmd_up() {
  local name="${1:-}"

  if [[ -z "$name" ]]; then
    local existing
    existing=$(hcloud server list -o noheader -o columns=name 2>/dev/null)
    if ! echo "$existing" | grep -qx 'workstation-main'; then
      name="workstation-main"
    else
      local last next
      last=$(echo "$existing" | grep -E '^workstation-test[0-9]+$' | sed 's/workstation-test//' | sort -n | tail -1 || true)
      next=$(( ${last:-0} + 1 ))
      name="workstation-test${next}"
    fi
  fi

  local server_type="cx23"
  local image="ubuntu-26.04"
  local location="hel1"

  # Get all SSH key names as comma-separated list
  local ssh_keys
  ssh_keys=$(hcloud ssh-key list -o noheader -o columns=name | paste -sd,)
  [[ -n "$ssh_keys" ]] || die "No SSH keys found in Hetzner account — add one first"

  echo "Creating server:"
  echo "  Name:        $name"
  echo "  Type:        $server_type"
  echo "  Image:       $image"
  echo "  Location:    $location"
  echo "  SSH keys:    $ssh_keys"
  echo ""

  hcloud server create \
    --name "$name" \
    --type "$server_type" \
    --image "$image" \
    --location "$location" \
    --ssh-key "$ssh_keys"

  echo "$name"
}

cmd_down() {
  local name="" yes=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y|--yes) yes=true ;;
      -*) die "Unknown option: $1" ;;
      *) name="$1" ;;
    esac
    shift
  done

  [[ -n "$name" ]] || die "Server name required: $SCRIPT_NAME down <name>"

  if ! hcloud server describe "$name" &>/dev/null; then
    if $yes; then
      echo "Server '$name' not found, nothing to do"
      exit 0
    fi
    die "Server '$name' not found"
  fi

  if ! $yes; then
    echo "Server to delete:"
    hcloud server describe "$name"
    echo ""
    read -rp "Delete server '$name'? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 0; }
  fi

  hcloud server delete "$name"
}

cmd_list() {
  hcloud server list
}

cmd_ssh_config() {
  local config_dir="$HOME/.ssh/config.d"
  mkdir -p "$config_dir"
  chmod 700 "$config_dir"

  local servers_json
  servers_json=$(hcloud server list -o json)

  SERVERS_JSON="$servers_json" CONFIG_DIR="$config_dir" python3 << 'PYEOF'
import json, os, glob

config_dir = os.environ["CONFIG_DIR"]
servers = json.loads(os.environ["SERVERS_JSON"])

written = set()
for s in servers:
    name = s["name"]
    ip = s["public_net"]["ipv4"]["ip"]
    filename = os.path.join(config_dir, f"hcloud-{name}")
    with open(filename, "w") as f:
        f.write(f"Host {name}\n    HostName {ip}\n")
    os.chmod(filename, 0o600)
    written.add(f"hcloud-{name}")
    print(f"  wrote {filename}")

for filepath in glob.glob(os.path.join(config_dir, "hcloud-*")):
    if os.path.basename(filepath) not in written:
        os.remove(filepath)
        print(f"  removed {filepath}")

print(f"SSH config synced: {len(servers)} server(s)")
PYEOF
}

require_hcloud

case "${1:-}" in
  up)         shift; cmd_up "$@" ;;
  down)       shift; cmd_down "$@" ;;
  list)       cmd_list ;;
  ssh-config) cmd_ssh_config ;;
  -h|--help|help) usage ;;
  "") usage; exit 1 ;;
  *) die "Unknown command: $1. Run '$SCRIPT_NAME --help' for usage." ;;
esac
